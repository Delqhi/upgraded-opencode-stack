// ╔══════════════════════════════════════════════════════════╗
// ║  OH-MY-OPENAGENT.json — Subagenten-Modell-Konfiguration  ║
// ╠══════════════════════════════════════════════════════════╣
// ║  WAS IST DAS?                                            ║
// ║  Dies ist die KANONISCHE Konfiguration für ALLE          ║
// ║  Subagenten-Modelle im OpenSIN Stack.                    ║
// ║                                                          ║
// ║  WANN WIRD DAS GENUTZT?                                  ║
// ║  Immer wenn ein Haupt-Agent (z.B. SIN-Zeus) an einen     ║
// ║  Subagenten delegiert:                                   ║
// ║    task(subagent_type="explore") → nutzt explore.model   ║
// ║    task(category="quick") → nutzt categories.quick.model ║
// ║                                                          ║
// ║  UNTERSCHIED ZU opencode.json:                           ║
// ║    opencode.json      → DEINE Agenten (die du siehst)    ║
// ║    oh-my-openagent.json → SUBAGENTEN (die im Hintergrund ║
// ║                           arbeiten wenn delegiert wird)  ║
// ╚══════════════════════════════════════════════════════════╝
//
// ╔══════════════════════════════════════════════════════════╗
// ║  🚨 PARALLEL-EXPLORATION PROTOCOL (ENTERPRISE)           ║
// ╠══════════════════════════════════════════════════════════╣
// ║  BEI GROSSEN CODEBASES (100k+ Zeilen, 1000+ Dateien):   ║
// ║  EIN einzelner explore-Agent liefert nur ~20% Abdeckung! ║
// ║                                                          ║
// ║  LOESUNG: IMMER 5-10 explore + 5-10 librarian-Agenten   ║
// ║  PARALLEL starten (run_in_background=true)!              ║
// ║                                                          ║
// ║  Beispiel (7 parallele explores):                        ║
// ║    task(subagent_type="explore", run_in_background=true, ║
// ║      load_skills=[], description="Find APIs",            ║
// ║      prompt="[CONTEXT]: Gross. [GOAL]: Alle APIs...")    ║
// ║    task(subagent_type="explore", run_in_background=true, ║
// ║      load_skills=[], description="Find Services",        ║
// ║      prompt="[CONTEXT]: Gross. [GOAL]: Alle Services...")║
// ║    ... (5 weitere parallele Agenten)                     ║
// ║                                                          ║
// ║  Siehe: skills/enterprise-parallel-exploration/SKILL.md  ║
// ╚══════════════════════════════════════════════════════════╝
{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // Automatisch zum nächsten Modell wechseln wenn das primäre ausfällt
  "model_fallback": true,

  // Diese Skills sind deaktiviert (spielen nicht mit unserem Stack zusammen)
  "disabled_skills": [
    "playwright",    // Playwright ist gebannt — wir nutzen nodriver
    "dev-browser"    // Dev-Browser kollidiert mit webauto-nodriver-mcp
  ],

  // ═══════════════════════════════════════════════════════════
  // AGENTEN — Spezifische Modelle für jeden Subagenten-Typ
  // ═══════════════════════════════════════════════════════════
  "agents": {

    // EXPLORE — Codebase erkunden, Dateien durchsuchen, Struktur verstehen
    // Nutzt Nemotron 3 Super 120B — stark für Analyse und breite Recherche
    "explore": {
      "model": "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // LIBRARIAN — Dokumentation lesen, Spezifikationen analysieren, Referenzen finden
    // Nutzt Nemotron 3 Super 120B — ideal für Doku, Specs und Referenzen
    "librarian": {
      "model": "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // ORACLE — Architektur-Analyse, Design-Entscheidungen, Best Practices
    // Nutzt GPT-5.4 — beste Architektur-Erkennung
    "oracle": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // MULTIMODAL-LOOKER — Bildanalyse, Screenshots auswerten, UI verstehen
    // Nutzt OpenAI GPT-5.4-mini — visionfähiges Modell für look_at
    "multimodal-looker": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // MOMUS — Plan-Kritiker, findet Fehler in Plänen, warnt vor Risiken
    // Nutzt Gemini 3.1 Pro — starkes kritisches Denken
    "momus": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // METIS — Plan-Berater, strategische Empfehlungen, Alternativen aufzeigen
    // Nutzt Gemini 3.1 Pro — starke strategische Analyse
    "metis": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // SISYPHUS — Ultraworker, endlose Aufgaben bis sie fertig sind
    // Nutzt Claude Opus 4.6 Thinking — tiefstes Nachdenken für komplexe Tasks
    "sisyphus": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // HEPHAESTUS — Deep Agent, tiefe Code-Analyse, komplexe Implementationen
    // Nutzt Claude Sonnet 4.6 — bestes Coding-Modell
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // ATLAS — Plan Executor, setzt Pläne in Code um
    // Nutzt Claude Opus 4.6 Thinking — durchdachteste Implementation
    "atlas": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // PROMETHEUS — Plan Builder, erstellt detaillierte Pläne
    // Nutzt Qwen 3.6 Plus — kostenlos und schnell für Plan-Erstellung
    "prometheus": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // SISYPHUS-JUNIOR — Fast-Ultraworker, schnellere Variante von Sisyphus
    // Nutzt Gemini 3.1 Pro — guter Kompromiss aus Geschwindigkeit und Qualität
    "sisyphus-junior": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    }
  },

  // ═══════════════════════════════════════════════════════════
  // KATEGORIEN — Modell-Auswahl wenn kein spezifischer Agent angegeben
  // ═══════════════════════════════════════════════════════════
  "categories": {

    // QUICK — Schnelle Antworten, einfache Fragen, kurze Tasks
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // DEEP — Tiefe Analysen, komplexe Probleme, umfangreiche Recherche
    "deep": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // ARTISTRY — Kreative Tasks, Design, UI/UX, visuelle Inhalte
    "artistry": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // ULTRABRAIN — Schwerste Probleme, maximale Denkleistung
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // VISUAL-ENGINEERING — UI/UX Tasks, Frontend-Design, Layout
    "visual-engineering": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // UNSPECIFIED-LOW — Unspezifische Tasks mit niedriger Priorität
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // UNSPECIFIED-HIGH — Unspezifische Tasks mit hoher Priorität
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // WRITING — Text-Generierung, Dokumentation, Copywriting
    "writing": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    }
  }
}
