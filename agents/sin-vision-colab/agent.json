{
  "id": "a2a-sin-vision-colab",
  "name": "A2A-SIN-Vision-Colab",
  "version": "4.0.0",
  "description": "Screen recording + AI vision analysis via OpenAI GPT models with standardized fallback chain. No browser, no Colab MCP, no CDP.",
  "team": "Team - Infrastructure",
  "manager": "SIN-Zeus",
  "status": "production-ready",
  "capabilities": [
    "screen_recording",
    "screenshot_capture",
    "vision_analysis",
    "gemini_rest_api",
    "multi_model_fallback",
    "supabase_logging",
    "continuous_monitoring"
  ],
  "models": {
    "primary": "openai/gpt-5.4-mini",
    "fallback_chain": [
      "nvidia-nim/z-ai/glm5.1",
      "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
      "nvidia-nim/stepfun-ai/step-3.5-flash"
    ]
  },
  "endpoints": {
    "cli": "~/.local/bin/look-screen"
  },
  "infrastructure": {
    "vm_type": "none (pure REST)",
    "integration": "Gemini REST API (generativelanguage.googleapis.com)",
    "browser_automation": "NONE"
  },
  "environment": {
    "required": ["GEMINI_VISION_API_KEY (default: YOUR_GEMINI_VISION_API_KEY)"],
    "optional": [
      "VISION_SUPABASE_URL",
      "VISION_SUPABASE_KEY"
    ]
  },
  "marketplace": {
    "pricingModel": "free",
    "monthlyPrice": 0,
    "purchaseModes": ["auto-include"]
  },
  "skills": ["sin-vision-colab"],
  "mcp_servers": [],
  "cli_commands": {
    "look-screen --status": "Show vision backend status (Gemini REST)",
    "look-screen --screenshot /tmp/screen.png --describe": "Analyze screenshot via Gemini REST API",
    "look-screen --once --screenshot /tmp/screen.png": "One-shot analysis via Gemini REST API",
    "look-screen --interval 3": "Continuous monitoring via Gemini REST API",
    "look-screen --record": "Start screen recording",
    "look-screen --stop": "Stop screen recording"
  },
  "agent_card": {
    "identity": {
      "name": "A2A-SIN-Vision-Colab",
      "version": "4.0.0",
    "description": "SOTA 2026 Vision Agent using OpenAI GPT primary with standardized fallback chain"
  },
    "capabilities": [
      {
        "name": "screen_record",
        "description": "Record screen and capture screenshots"
      },
      {
        "name": "vision_analyze",
        "description": "Analyze screenshots via Gemini REST API with automatic model fallback"
      }
    ],
    "default_input_modes": ["text", "image"],
    "default_output_modes": ["text"]
  }
}
