#!/usr/bin/env python3
"""
sin-telegrambot — SIN Fleet Telegram Bot CLI
Manages multiple Telegram bots from the terminal.
Auto-bootstraps chat_id via Telegram.app AppleScript (no manual /start needed).
"""

import argparse
import json
import os
import subprocess
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path

CONFIG_DIR = Path.home() / ".config" / "sin-telegrambot"
BOTS_FILE = CONFIG_DIR / "bots.json"
CONFIG_DIR.mkdir(parents=True, exist_ok=True)


def load_bots() -> dict:
    if BOTS_FILE.exists():
        return json.loads(BOTS_FILE.read_text())
    return {}


def save_bots(bots: dict):
    BOTS_FILE.write_text(json.dumps(bots, indent=2, ensure_ascii=False))


def tg_get(token: str, method: str, **params) -> dict:
    qs = urllib.parse.urlencode(params)
    url = f"https://api.telegram.org/bot{token}/{method}?{qs}"
    resp = urllib.request.urlopen(url, timeout=10)
    return json.loads(resp.read())


def tg_post(token: str, method: str, payload: dict) -> dict:
    url = f"https://api.telegram.org/bot{token}/{method}"
    data = json.dumps(payload).encode()
    req = urllib.request.Request(
        url, data=data, headers={"Content-Type": "application/json"}
    )
    try:
        resp = urllib.request.urlopen(req, timeout=10)
        return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        body = e.read().decode()
        raise RuntimeError(f"Telegram {method} failed: {e} — {body}")


def resolve_token(bot_name: str) -> str:
    bots = load_bots()
    if bot_name in bots:
        return bots[bot_name]["token"]
    env_key = f"TELEGRAM_BOT_TOKEN_{bot_name.upper().replace('-', '_')}"
    token = os.environ.get(env_key, "")
    if token:
        return token
    raise RuntimeError(
        f"Bot '{bot_name}' not registered. Use: sin-telegrambot register <name> <token>"
    )


def resolve_chat_id(token: str, bot_name: str) -> str:
    bots = load_bots()
    if bot_name in bots and bots[bot_name].get("chat_id"):
        return str(bots[bot_name]["chat_id"])
    env_chat = os.environ.get("SINPATENT_CHAT_ID", "") or os.environ.get(
        "TELEGRAM_CHAT_ID", ""
    )
    if env_chat:
        return env_chat
    discovered = _discover_chat_id(token)
    if discovered:
        if bot_name in bots:
            bots[bot_name]["chat_id"] = discovered
            save_bots(bots)
        return discovered
    raise RuntimeError(
        f"No chat_id for bot '{bot_name}'. Use: sin-telegrambot bootstrap <name>"
    )


def _discover_chat_id(token: str) -> str:
    try:
        data = tg_get(token, "getUpdates", limit=50, timeout=0)
        for upd in reversed(data.get("result", [])):
            msg = upd.get("message") or upd.get("callback_query", {}).get("message")
            if msg and msg.get("chat", {}).get("id"):
                return str(msg["chat"]["id"])
    except Exception:
        pass
    return ""


def _applescript_send_start(bot_username: str):
    script = f"""
tell application "Telegram"
    activate
end tell
delay 1.5
tell application "System Events"
    tell process "Telegram"
        keystroke "k" using command down
        delay 0.8
        keystroke "@{bot_username}"
        delay 1.2
        key code 36
        delay 1.0
        keystroke "/start"
        key code 36
    end tell
end tell
"""
    subprocess.run(["osascript", "-e", script], capture_output=True, timeout=15)


def cmd_register(args):
    bots = load_bots()
    try:
        info = tg_get(args.token, "getMe")
        username = info["result"]["username"]
        name = args.name or username
        bots[name] = {
            "token": args.token,
            "username": username,
            "chat_id": args.chat_id or "",
        }
        save_bots(bots)
        print(
            json.dumps({"ok": True, "registered": name, "username": username}, indent=2)
        )
    except Exception as e:
        print(json.dumps({"ok": False, "error": str(e)}, indent=2))
        sys.exit(1)


def cmd_list(args):
    bots = load_bots()
    if not bots:
        print("No bots registered. Use: sin-telegrambot register <name> <token>")
        return
    rows = []
    for name, meta in bots.items():
        rows.append(
            {
                "name": name,
                "username": meta.get("username", "?"),
                "chat_id": meta.get("chat_id", ""),
                "token_preview": meta["token"][:20] + "...",
            }
        )
    print(json.dumps(rows, indent=2))


def cmd_bootstrap(args):
    token = resolve_token(args.name)
    bots = load_bots()
    meta = bots.get(args.name, {})
    username = meta.get("username", "")

    chat_id = _discover_chat_id(token)
    if chat_id:
        print(f"[OK] Chat ID already known from updates: {chat_id}")
    else:
        if username:
            print(f"[INFO] Sending /start to @{username} via Telegram.app ...")
            _applescript_send_start(username)
            print("[INFO] Waiting for update (up to 30s) ...")
            deadline = time.time() + 30
            while time.time() < deadline:
                time.sleep(2)
                chat_id = _discover_chat_id(token)
                if chat_id:
                    break
        if not chat_id:
            chat_id = input(
                "[INPUT] Could not auto-discover. Enter chat_id manually: "
            ).strip()

    if chat_id:
        if args.name not in bots:
            bots[args.name] = {"token": token, "username": username, "chat_id": chat_id}
        else:
            bots[args.name]["chat_id"] = chat_id
        save_bots(bots)
        print(json.dumps({"ok": True, "chat_id": chat_id}, indent=2))
    else:
        print(json.dumps({"ok": False, "error": "chat_id not found"}, indent=2))
        sys.exit(1)


def cmd_send(args):
    token = resolve_token(args.bot)
    chat_id = args.chat_id or resolve_chat_id(token, args.bot)
    payload: dict = {
        "chat_id": chat_id,
        "text": args.message,
        "parse_mode": args.parse_mode,
    }
    if args.buttons:
        try:
            buttons = json.loads(args.buttons)
            payload["reply_markup"] = {"inline_keyboard": buttons}
        except json.JSONDecodeError:
            print(f"[WARN] --buttons is not valid JSON, ignoring")

    try:
        result = tg_post(token, "sendMessage", payload)
        print(
            json.dumps(
                {"ok": True, "message_id": result["result"]["message_id"]}, indent=2
            )
        )
    except Exception as e:
        print(json.dumps({"ok": False, "error": str(e)}, indent=2))
        sys.exit(1)


def cmd_send_document(args):
    token = resolve_token(args.bot)
    chat_id = args.chat_id or resolve_chat_id(token, args.bot)
    file_path = Path(args.file)
    if not file_path.exists():
        print(json.dumps({"ok": False, "error": f"File not found: {args.file}"}))
        sys.exit(1)
    import mimetypes

    mime = mimetypes.guess_type(str(file_path))[0] or "application/octet-stream"
    boundary = "----SINTelegramBoundary"
    body_parts = []
    body_parts.append(
        f'--{boundary}\r\nContent-Disposition: form-data; name="chat_id"\r\n\r\n{chat_id}'.encode()
    )
    if args.caption:
        body_parts.append(
            f'--{boundary}\r\nContent-Disposition: form-data; name="caption"\r\n\r\n{args.caption}'.encode()
        )
    file_data = file_path.read_bytes()
    body_parts.append(
        f'--{boundary}\r\nContent-Disposition: form-data; name="document"; filename="{file_path.name}"\r\nContent-Type: {mime}\r\n\r\n'.encode()
        + file_data
    )
    body_parts.append(f"--{boundary}--\r\n".encode())
    body = b"\r\n".join(body_parts)
    url = f"https://api.telegram.org/bot{token}/sendDocument"
    req = urllib.request.Request(
        url,
        data=body,
        headers={"Content-Type": f"multipart/form-data; boundary={boundary}"},
    )
    try:
        resp = urllib.request.urlopen(req, timeout=30)
        result = json.loads(resp.read())
        print(
            json.dumps(
                {"ok": True, "message_id": result["result"]["message_id"]}, indent=2
            )
        )
    except urllib.error.HTTPError as e:
        body_err = e.read().decode()
        print(json.dumps({"ok": False, "error": body_err}, indent=2))
        sys.exit(1)


def cmd_updates(args):
    token = resolve_token(args.bot)
    try:
        data = tg_get(token, "getUpdates", limit=args.limit or 20, timeout=0)
        print(json.dumps(data["result"], indent=2))
    except Exception as e:
        print(json.dumps({"ok": False, "error": str(e)}, indent=2))
        sys.exit(1)


def cmd_status(args):
    token = resolve_token(args.bot)
    try:
        me = tg_get(token, "getMe")
        webhook = tg_get(token, "getWebhookInfo")
        chat_id = _discover_chat_id(token)
        print(
            json.dumps(
                {
                    "bot": me["result"],
                    "webhook": webhook["result"],
                    "known_chat_id": chat_id,
                },
                indent=2,
            )
        )
    except Exception as e:
        print(json.dumps({"ok": False, "error": str(e)}, indent=2))
        sys.exit(1)


def cmd_set_webhook(args):
    token = resolve_token(args.bot)
    try:
        result = tg_post(
            token, "setWebhook", {"url": args.url, "secret_token": args.secret or ""}
        )
        print(json.dumps(result, indent=2))
    except Exception as e:
        print(json.dumps({"ok": False, "error": str(e)}, indent=2))
        sys.exit(1)


def cmd_delete_webhook(args):
    token = resolve_token(args.bot)
    try:
        result = tg_post(token, "deleteWebhook", {"drop_pending_updates": False})
        print(json.dumps(result, indent=2))
    except Exception as e:
        print(json.dumps({"ok": False, "error": str(e)}, indent=2))
        sys.exit(1)


def cmd_set_commands(args):
    token = resolve_token(args.bot)
    try:
        commands = json.loads(args.commands_json)
        result = tg_post(token, "setMyCommands", {"commands": commands})
        print(json.dumps(result, indent=2))
    except Exception as e:
        print(json.dumps({"ok": False, "error": str(e)}, indent=2))
        sys.exit(1)


def cmd_register_from_env(args):
    env_file = Path(args.env_file) if args.env_file else Path(".env")
    env_vars = {}
    if env_file.exists():
        for line in env_file.read_text().splitlines():
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                k, _, v = line.partition("=")
                env_vars[k.strip()] = v.strip().strip('"').strip("'")
    env_vars = {**env_vars, **os.environ}

    token = env_vars.get("TELEGRAM_BOT_TOKEN", "")
    if not token:
        print(
            json.dumps(
                {"ok": False, "error": "TELEGRAM_BOT_TOKEN not set in env or .env"}
            )
        )
        sys.exit(1)

    name = args.name or env_vars.get("TELEGRAM_BOT_NAME", "")
    chat_id = (
        args.chat_id
        or env_vars.get("TELEGRAM_CHAT_ID", "")
        or env_vars.get("SINPATENT_CHAT_ID", "")
    )

    fake_args = argparse.Namespace(
        token=token, name=name or None, chat_id=chat_id or None
    )
    cmd_register(fake_args)

    if not chat_id:
        bots = load_bots()
        registered_name = name or list(bots.keys())[-1]
        boot_args = argparse.Namespace(name=registered_name)
        cmd_bootstrap(boot_args)


def cmd_poll(args):
    token = resolve_token(args.bot)
    print(f"[INFO] Polling @{args.bot} for updates (Ctrl+C to stop) ...")
    offset = 0
    while True:
        try:
            data = tg_get(token, "getUpdates", offset=offset, limit=10, timeout=30)
            for upd in data.get("result", []):
                offset = upd["update_id"] + 1
                print(json.dumps(upd, ensure_ascii=False))
        except KeyboardInterrupt:
            break
        except Exception as e:
            print(f"[WARN] {e}", file=sys.stderr)
            time.sleep(3)


def main():
    parser = argparse.ArgumentParser(
        prog="sin-telegrambot",
        description="SIN Fleet Telegram Bot CLI — manage bots from the terminal",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    p_reg = sub.add_parser("register", help="Register a bot by token")
    p_reg.add_argument("token", help="Bot token from BotFather")
    p_reg.add_argument("--name", help="Local alias (defaults to bot username)")
    p_reg.add_argument("--chat-id", dest="chat_id", help="Known chat_id (optional)")
    p_reg.set_defaults(func=cmd_register)

    p_list = sub.add_parser("list", help="List registered bots")
    p_list.set_defaults(func=cmd_list)

    p_boot = sub.add_parser("bootstrap", help="Auto-discover chat_id via Telegram.app")
    p_boot.add_argument("name", help="Bot alias")
    p_boot.set_defaults(func=cmd_bootstrap)

    p_send = sub.add_parser("send", help="Send a message")
    p_send.add_argument("bot", help="Bot alias")
    p_send.add_argument("message", help="Message text")
    p_send.add_argument("--chat-id", dest="chat_id", help="Override chat_id")
    p_send.add_argument(
        "--parse-mode", dest="parse_mode", default="HTML", help="HTML or Markdown"
    )
    p_send.add_argument(
        "--buttons", help="Inline keyboard JSON [[{text,callback_data}]]"
    )
    p_send.set_defaults(func=cmd_send)

    p_doc = sub.add_parser("send-document", help="Send a file/document")
    p_doc.add_argument("bot", help="Bot alias")
    p_doc.add_argument("file", help="File path")
    p_doc.add_argument("--chat-id", dest="chat_id", help="Override chat_id")
    p_doc.add_argument("--caption", help="File caption")
    p_doc.set_defaults(func=cmd_send_document)

    p_upd = sub.add_parser("updates", help="Fetch recent updates")
    p_upd.add_argument("bot", help="Bot alias")
    p_upd.add_argument("--limit", type=int, default=20)
    p_upd.set_defaults(func=cmd_updates)

    p_stat = sub.add_parser(
        "status", help="Show bot status, webhook info, known chat_id"
    )
    p_stat.add_argument("bot", help="Bot alias")
    p_stat.set_defaults(func=cmd_status)

    p_wh = sub.add_parser("set-webhook", help="Set webhook URL")
    p_wh.add_argument("bot", help="Bot alias")
    p_wh.add_argument("url", help="HTTPS webhook URL")
    p_wh.add_argument("--secret", help="Webhook secret token")
    p_wh.set_defaults(func=cmd_set_webhook)

    p_dwh = sub.add_parser("delete-webhook", help="Delete webhook (switch to polling)")
    p_dwh.add_argument("bot", help="Bot alias")
    p_dwh.set_defaults(func=cmd_delete_webhook)

    p_cmd = sub.add_parser("set-commands", help="Set bot command menu")
    p_cmd.add_argument("bot", help="Bot alias")
    p_cmd.add_argument(
        "commands_json", help='JSON: [{"command":"start","description":"..."}]'
    )
    p_cmd.set_defaults(func=cmd_set_commands)

    p_rfe = sub.add_parser(
        "register-from-env", help="Auto-register bot from TELEGRAM_BOT_TOKEN in .env"
    )
    p_rfe.add_argument(
        "--env-file", dest="env_file", help="Path to .env file (default: ./.env)"
    )
    p_rfe.add_argument(
        "--name", help="Override bot alias (default: TELEGRAM_BOT_NAME from env)"
    )
    p_rfe.add_argument(
        "--chat-id",
        dest="chat_id",
        help="Override chat_id (default: TELEGRAM_CHAT_ID from env)",
    )
    p_rfe.set_defaults(func=cmd_register_from_env)

    p_poll = sub.add_parser("poll", help="Live-poll updates (dev mode)")
    p_poll.add_argument("bot", help="Bot alias")
    p_poll.set_defaults(func=cmd_poll)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
