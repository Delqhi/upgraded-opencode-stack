#!/usr/bin/env python3
import argparse
import json
import os
import sys
import urllib.request
import urllib.error
from pathlib import Path
from typing import Any, Dict, Iterable, Optional

from google.oauth2 import service_account
from google.oauth2.credentials import Credentials as UserCredentials
from google.auth.transport.requests import Request
from googleapiclient.discovery import build

DEFAULT_CREDS = "/Users/jeremy/.config/opencode/auth/google/zukunftsorientierte.energie@gmail.com.json"
DEFAULT_ACCOUNT_KEY = "private-main"
DEFAULT_USER_OAUTH_ROOT = "/Users/jeremy/.config/google/sin-google-apps/accounts"
SCOPES = [
    "https://www.googleapis.com/auth/documents",
    "https://www.googleapis.com/auth/drive",
]


def _utf16_len(text: str) -> int:
    return len(text.encode("utf-16-le")) // 2


def _print(obj: Dict[str, Any]) -> None:
    print(json.dumps(obj, ensure_ascii=False))


def get_credentials_path() -> str:
    return os.environ.get("GOOGLE_SERVICE_ACCOUNT_PATH") or DEFAULT_CREDS


def get_user_oauth_path(account_key: Optional[str]) -> str:
    key = account_key or DEFAULT_ACCOUNT_KEY
    return str(Path(DEFAULT_USER_OAUTH_ROOT) / key / "user-oauth.json")


def get_user_access_token(account_key: Optional[str]) -> str:
    oauth_path = get_user_oauth_path(account_key)
    if not Path(oauth_path).exists():
        raise FileNotFoundError(f"Missing Google user OAuth token file: {oauth_path}")
    data = json.loads(Path(oauth_path).read_text(encoding="utf-8"))
    token = data.get("access_token") or data.get("token")
    if not token:
        raise ValueError(f"OAuth token file has no access token: {oauth_path}")
    return token


def load_credentials(
    auth_mode: str = "service_account", account_key: Optional[str] = None
):
    if auth_mode == "user_oauth":
        oauth_path = get_user_oauth_path(account_key)
        if not Path(oauth_path).exists():
            raise FileNotFoundError(
                f"Missing Google user OAuth token file: {oauth_path}"
            )
        data = json.loads(Path(oauth_path).read_text(encoding="utf-8"))
        try:
            if data.get("client_secret"):
                creds = UserCredentials.from_authorized_user_info(data, SCOPES)
                if creds.expired and creds.refresh_token:
                    creds.refresh(Request())
                    Path(oauth_path).write_text(creds.to_json())
                return creds
        except Exception:
            pass
        access_token = data.get("access_token") or data.get("token")
        if not access_token:
            raise ValueError(
                f"OAuth token file has no usable access token: {oauth_path}"
            )
        # Fallback: use current bearer token directly when the custom token store lacks client_secret.
        return UserCredentials(token=access_token, scopes=SCOPES)
    creds_path = get_credentials_path()
    if not Path(creds_path).exists():
        raise FileNotFoundError(
            f"Missing Google service-account credentials: {creds_path}"
        )
    return service_account.Credentials.from_service_account_file(
        creds_path, scopes=SCOPES
    )


def get_docs_service(
    auth_mode: str = "service_account", account_key: Optional[str] = None
):
    return build(
        "docs",
        "v1",
        credentials=load_credentials(auth_mode=auth_mode, account_key=account_key),
    )


def get_drive_service(
    auth_mode: str = "service_account", account_key: Optional[str] = None
):
    return build(
        "drive",
        "v3",
        credentials=load_credentials(auth_mode=auth_mode, account_key=account_key),
    )


def get_service_account_email() -> Optional[str]:
    creds_path = get_credentials_path()
    if not Path(creds_path).exists():
        return None
    try:
        data = json.loads(Path(creds_path).read_text(encoding="utf-8"))
        return data.get("client_email")
    except Exception:
        return None


def fetch_document(service, document_id: str) -> Dict[str, Any]:
    return (
        service.documents()
        .get(documentId=document_id, includeTabsContent=True)
        .execute()
    )


def iter_tabs(tabs: Iterable[Dict[str, Any]], parent_title: Optional[str] = None):
    for tab in tabs or []:
        props = tab.get("tabProperties", {})
        title = props.get("title")
        tab_id = props.get("tabId")
        index = props.get("index")
        yield {
            "title": title,
            "tabId": tab_id,
            "index": index,
            "parentTitle": parent_title,
            "raw": tab,
        }
        for child in iter_tabs(tab.get("childTabs", []), title):
            yield child


def resolve_tab(
    document: Dict[str, Any], tab_id: Optional[str] = None, title: Optional[str] = None
) -> Dict[str, Any]:
    tabs = list(iter_tabs(document.get("tabs", [])))
    if tab_id:
        for tab in tabs:
            if tab["tabId"] == tab_id:
                return tab
        raise KeyError(f"Tab not found by id: {tab_id}")
    if title:
        for tab in tabs:
            if tab["title"] == title:
                return tab
        raise KeyError(f"Tab not found by title: {title}")
    if tabs:
        return tabs[0]
    raise KeyError("No tabs available in document")


def get_tab_content_elements(tab_raw: Dict[str, Any]):
    document_tab = tab_raw.get("documentTab", {})
    body = document_tab.get("body", {})
    return body.get("content", [])


def get_tab_end_index(tab_raw: Dict[str, Any]) -> int:
    content = get_tab_content_elements(tab_raw)
    if not content:
        return 1
    return max(1, content[-1].get("endIndex", 1) - 1)


def structural_text(elements: Iterable[Dict[str, Any]]) -> str:
    parts = []
    for el in elements:
        if "paragraph" in el:
            for child in el["paragraph"].get("elements", []):
                tr = child.get("textRun")
                if tr:
                    parts.append(tr.get("content", ""))
        if "table" in el:
            for row in el["table"].get("tableRows", []):
                row_texts = []
                for cell in row.get("tableCells", []):
                    row_texts.append(structural_text(cell.get("content", [])))
                parts.append("\t".join(t.strip() for t in row_texts if t is not None))
                parts.append("\n")
        if "tableOfContents" in el:
            parts.append(structural_text(el["tableOfContents"].get("content", [])))
    return "".join(parts)


def read_text_arg(text: Optional[str], text_file: Optional[str]) -> str:
    if text_file:
        return Path(text_file).read_text(encoding="utf-8")
    return text or ""


def resolve_patent_files(patent_dir: str) -> Dict[str, Path]:
    base = Path(patent_dir)
    if not base.exists():
        raise FileNotFoundError(f"Patent directory not found: {patent_dir}")
    files = {
        "claims": base / "Schutzansprüche.md",
        "description": base / "Technische-Beschreibung.md",
        "summary": base / "Zusammenfassung.md",
        "drawings": base / "Zeichnungen" / "Figuren.md",
    }
    return files


def replace_tab_content(
    service, document_id: str, tab: Dict[str, Any], text: str
) -> Dict[str, Any]:
    requests = []
    end_index = get_tab_end_index(tab["raw"])
    if end_index > 1:
        requests.append(
            {
                "deleteContentRange": {
                    "range": {
                        "tabId": tab["tabId"],
                        "startIndex": 1,
                        "endIndex": end_index,
                    }
                }
            }
        )
    if text:
        requests.append(
            {
                "insertText": {
                    "location": {
                        "tabId": tab["tabId"],
                        "index": 1,
                    },
                    "text": text,
                }
            }
        )
    if requests:
        service.documents().batchUpdate(
            documentId=document_id, body={"requests": requests}
        ).execute()
    return {"tabId": tab["tabId"], "replacedChars": _utf16_len(text)}


def cmd_tabs(args):
    try:
        service = get_docs_service(
            auth_mode=args.auth_mode, account_key=getattr(args, "account_key", None)
        )
        doc = fetch_document(service, args.document_id)
        tabs = [
            {
                "title": tab["title"],
                "tabId": tab["tabId"],
                "index": tab["index"],
                "parentTitle": tab["parentTitle"],
            }
            for tab in iter_tabs(doc.get("tabs", []))
        ]
        _print({"ok": True, "documentId": args.document_id, "tabs": tabs})
    except Exception as e:
        _print({"ok": False, "error": str(e)})
        sys.exit(1)


def cmd_read(args):
    try:
        service = get_docs_service(
            auth_mode=args.auth_mode, account_key=getattr(args, "account_key", None)
        )
        doc = fetch_document(service, args.document_id)
        tab = resolve_tab(doc, tab_id=args.tab_id, title=args.title)
        text = structural_text(get_tab_content_elements(tab["raw"]))
        _print(
            {
                "ok": True,
                "documentId": args.document_id,
                "tab": {
                    "title": tab["title"],
                    "tabId": tab["tabId"],
                    "index": tab["index"],
                    "parentTitle": tab["parentTitle"],
                },
                "text": text,
            }
        )
    except Exception as e:
        _print({"ok": False, "error": str(e)})
        sys.exit(1)


def cmd_clear(args):
    try:
        service = get_docs_service(
            auth_mode=args.auth_mode, account_key=getattr(args, "account_key", None)
        )
        doc = fetch_document(service, args.document_id)
        tab = resolve_tab(doc, tab_id=args.tab_id, title=args.title)
        end_index = get_tab_end_index(tab["raw"])
        if end_index <= 1:
            _print({"ok": True, "cleared": 0, "tabId": tab["tabId"]})
            return
        body = {
            "requests": [
                {
                    "deleteContentRange": {
                        "range": {
                            "tabId": tab["tabId"],
                            "startIndex": 1,
                            "endIndex": end_index,
                        }
                    }
                }
            ]
        }
        service.documents().batchUpdate(
            documentId=args.document_id, body=body
        ).execute()
        _print({"ok": True, "cleared": end_index - 1, "tabId": tab["tabId"]})
    except Exception as e:
        _print({"ok": False, "error": str(e)})
        sys.exit(1)


def cmd_replace(args):
    try:
        service = get_docs_service(
            auth_mode=args.auth_mode, account_key=getattr(args, "account_key", None)
        )
        doc = fetch_document(service, args.document_id)
        tab = resolve_tab(doc, tab_id=args.tab_id, title=args.title)
        text = read_text_arg(args.text, args.text_file)
        requests = []
        end_index = get_tab_end_index(tab["raw"])
        if end_index > 1:
            requests.append(
                {
                    "deleteContentRange": {
                        "range": {
                            "tabId": tab["tabId"],
                            "startIndex": 1,
                            "endIndex": end_index,
                        }
                    }
                }
            )
        if text:
            requests.append(
                {
                    "insertText": {
                        "location": {
                            "tabId": tab["tabId"],
                            "index": 1,
                        },
                        "text": text,
                    }
                }
            )
        if requests:
            service.documents().batchUpdate(
                documentId=args.document_id, body={"requests": requests}
            ).execute()
        _print({"ok": True, "tabId": tab["tabId"], "replacedChars": _utf16_len(text)})
    except Exception as e:
        _print({"ok": False, "error": str(e)})
        sys.exit(1)


def cmd_append(args):
    try:
        service = get_docs_service(
            auth_mode=args.auth_mode, account_key=getattr(args, "account_key", None)
        )
        doc = fetch_document(service, args.document_id)
        tab = resolve_tab(doc, tab_id=args.tab_id, title=args.title)
        text = read_text_arg(args.text, args.text_file)
        end_index = get_tab_end_index(tab["raw"])
        insert_index = max(1, end_index)
        body = {
            "requests": [
                {
                    "insertText": {
                        "location": {
                            "tabId": tab["tabId"],
                            "index": insert_index,
                        },
                        "text": text,
                    }
                }
            ]
        }
        service.documents().batchUpdate(
            documentId=args.document_id, body=body
        ).execute()
        _print({"ok": True, "tabId": tab["tabId"], "appendedChars": _utf16_len(text)})
    except Exception as e:
        _print({"ok": False, "error": str(e)})
        sys.exit(1)


def cmd_ensure_access(args):
    try:
        grantee = args.grantee_email or get_service_account_email()
        if not grantee:
            raise ValueError(
                "No grantee_email provided and no client_email found in credentials"
            )
        if args.auth_mode == "user_oauth":
            token = get_user_access_token(getattr(args, "account_key", None))
            list_req = urllib.request.Request(
                f"https://www.googleapis.com/drive/v3/files/{args.file_id}/permissions?fields=permissions(id,emailAddress,role,type)",
                headers={"Authorization": f"Bearer {token}"},
            )
            with urllib.request.urlopen(list_req, timeout=30) as resp:
                perms = json.loads(resp.read().decode()).get("permissions", [])
            for perm in perms:
                if perm.get("emailAddress") == grantee:
                    _print(
                        {
                            "ok": True,
                            "fileId": args.file_id,
                            "grantee": grantee,
                            "role": perm.get("role"),
                            "alreadyPresent": True,
                            "authMode": "user_oauth",
                        }
                    )
                    return
            body = json.dumps(
                {"type": "user", "role": args.role, "emailAddress": grantee}
            ).encode("utf-8")
            create_req = urllib.request.Request(
                f"https://www.googleapis.com/drive/v3/files/{args.file_id}/permissions?sendNotificationEmail={'true' if args.notify else 'false'}&fields=id,type,role,emailAddress",
                data=body,
                headers={
                    "Authorization": f"Bearer {token}",
                    "Content-Type": "application/json",
                },
                method="POST",
            )
            with urllib.request.urlopen(create_req, timeout=30) as resp:
                created = json.loads(resp.read().decode())
            _print(
                {
                    "ok": True,
                    "fileId": args.file_id,
                    "grantee": grantee,
                    "permission": created,
                    "alreadyPresent": False,
                    "authMode": "user_oauth",
                }
            )
            return
        drive = get_drive_service(
            auth_mode=args.auth_mode, account_key=getattr(args, "account_key", None)
        )
        perms = (
            drive.permissions()
            .list(fileId=args.file_id, fields="permissions(id,emailAddress,role,type)")
            .execute()
            .get("permissions", [])
        )
        for perm in perms:
            if perm.get("emailAddress") == grantee:
                _print(
                    {
                        "ok": True,
                        "fileId": args.file_id,
                        "grantee": grantee,
                        "role": perm.get("role"),
                        "alreadyPresent": True,
                        "authMode": args.auth_mode,
                    }
                )
                return
        created = (
            drive.permissions()
            .create(
                fileId=args.file_id,
                body={"type": "user", "role": args.role, "emailAddress": grantee},
                sendNotificationEmail=args.notify,
                fields="id,type,role,emailAddress",
            )
            .execute()
        )
        _print(
            {
                "ok": True,
                "fileId": args.file_id,
                "grantee": grantee,
                "permission": created,
                "alreadyPresent": False,
                "authMode": args.auth_mode,
            }
        )
    except Exception as e:
        _print(
            {
                "ok": False,
                "error": str(e),
                "hint": "Use OAuth owner credentials or browser self-share when the acting identity cannot change Drive permissions.",
            }
        )
        sys.exit(1)


def cmd_self_share_browser(args):
    import asyncio
    import sys as _sys

    _sys.path.insert(
        0,
        "/Users/jeremy/dev/SIN-Solver/a2a/team-infratructur/A2A-SIN-Google-Apps/scripts",
    )
    from docs_browser.browser_connect import connect, stop
    from docs_browser.page_target import ensure_page
    from docs_browser.docs_url import doc_url
    from docs_browser.docs_wait import wait_for_docs_load

    async def _run():
        browser = await connect("127.0.0.1", args.port, args.profile)
        try:
            page = await ensure_page(browser)
            await page.get(doc_url(args.document_id))
            await wait_for_docs_load(page, 25)
            await asyncio.sleep(2)
            email = args.grantee_email or get_service_account_email()
            if not email:
                raise ValueError("No grantee email available")
            result = await page.evaluate(
                rf"""
                JSON.stringify((async () => {{
                  const sleep = (ms) => new Promise(r => setTimeout(r, ms));
                  const isVisible = (el, doc=document) => {{
                    const s = (doc.defaultView || window).getComputedStyle(el);
                    const r = el.getBoundingClientRect();
                    return s.display !== 'none' && s.visibility !== 'hidden' && r.width > 0 && r.height > 0;
                  }};
                  const clean = (v) => (v || '').replace(/\s+/g,' ').trim();
                  const clickEl = (el) => {{
                    const rect = el.getBoundingClientRect();
                    const x = rect.left + rect.width / 2;
                    const y = rect.top + rect.height / 2;
                    for (const type of ['pointerdown','mousedown','pointerup','mouseup','click']) {{
                      el.dispatchEvent(new MouseEvent(type, {{ bubbles:true, cancelable:true, clientX:x, clientY:y, button:0, buttons:1 }}));
                    }}
                  }};
                  const buttons = [...document.querySelectorAll('button,[role="button"],div[role="button"],span[role="button"]')].filter(el => isVisible(el));
                  const shareBtn = buttons.find(el => clean(el.innerText || el.textContent || el.getAttribute('aria-label')).includes('Teilen'));
                  if (!shareBtn) return {{ok:false, step:'share-button-not-found'}};
                  clickEl(shareBtn);
                  await sleep(4000);
                  const frame = document.querySelector('iframe.share-client-content-iframe');
                  if (!frame) return {{ok:false, step:'iframe-not-found'}};
                  const doc = frame.contentDocument || frame.contentWindow?.document;
                  if (!doc) return {{ok:false, step:'iframe-doc-not-found'}};
                  const inputs = [...doc.querySelectorAll('input,textarea,[contenteditable="true"]')].filter(el => isVisible(el, doc));
                  const input = inputs.find(el => (el.getAttribute('aria-label') || '').includes('Personen'));
                  if (!input) return {{ok:false, step:'share-input-not-found'}};
                  input.focus();
                  input.value = {email!r};
                  input.dispatchEvent(new Event('input', {{ bubbles: true }}));
                  input.dispatchEvent(new Event('change', {{ bubbles: true }}));
                  await sleep(1200);
                  input.dispatchEvent(new KeyboardEvent('keydown', {{ key: 'Enter', code: 'Enter', bubbles: true }}));
                  input.dispatchEvent(new KeyboardEvent('keyup', {{ key: 'Enter', code: 'Enter', bubbles: true }}));
                  await sleep(2500);
                  const frameButtons = [...doc.querySelectorAll('button,[role="button"],div[role="button"],span[role="button"]')].filter(el => isVisible(el, doc));
                  const doneBtn = frameButtons.find(el => ['Fertig','Senden'].includes(clean(el.innerText || el.textContent || el.getAttribute('aria-label'))));
                  if (!doneBtn) return {{ok:false, step:'done-button-not-found', buttons: frameButtons.map(el => clean(el.innerText || el.textContent || el.getAttribute('aria-label'))).filter(Boolean)}};
                  clickEl(doneBtn);
                  await sleep(5000);
                  return {{ok:true, step:'done-clicked', email:{email!r}}};
                }})())
                """
            )
            try:
                return (
                    json.loads(result)
                    if isinstance(result, str) and result
                    else {"ok": False, "error": "empty_result"}
                )
            except Exception:
                return {"ok": False, "error": "invalid_result", "raw": result}
        finally:
            await stop(browser)

    try:
        res = asyncio.run(_run())
        _print(res)
        if not res.get("ok"):
            sys.exit(1)
    except Exception as e:
        _print({"ok": False, "error": str(e)})
        sys.exit(1)


def cmd_create_child_tab(args):
    _print(
        {
            "ok": False,
            "unsupported": True,
            "error": "Google Docs API does not currently support programmatic tab or child-tab creation.",
            "hint": "Create the child tab once in the Google Docs UI, then use sin-google-docs tabs/read/replace/clear/replace-patent-tabs to manage it programmatically.",
        }
    )
    sys.exit(1)


def cmd_ensure_patent_structure(args):
    try:
        service = get_docs_service(
            auth_mode=args.auth_mode, account_key=getattr(args, "account_key", None)
        )
        doc = fetch_document(service, args.document_id)
        expected = {
            "claims": args.claims_title or "Schutzansprüche",
            "description": args.description_title or "Techn. Beschreibung",
            "summary": args.summary_title or "Zusammenfassung",
            "drawings": args.drawings_title or "Zeichnungen",
        }
        tabs = list(iter_tabs(doc.get("tabs", [])))
        titles = {tab["title"]: tab["tabId"] for tab in tabs}
        missing = [title for title in expected.values() if title not in titles]
        present = {
            k: {"title": title, "tabId": titles.get(title)}
            for k, title in expected.items()
            if title in titles
        }
        _print(
            {
                "ok": len(missing) == 0,
                "documentId": args.document_id,
                "present": present,
                "missing": missing,
                "canCreateViaApi": False,
                "hint": "Missing tabs must be created once in the Google Docs UI; afterward the CLI can fully manage their contents.",
            }
        )
        if missing:
            sys.exit(1)
    except Exception as e:
        _print({"ok": False, "error": str(e)})
        sys.exit(1)


def cmd_insert_image(args):
    try:
        service = get_docs_service(
            auth_mode=args.auth_mode, account_key=getattr(args, "account_key", None)
        )
        doc = fetch_document(service, args.document_id)
        tab = resolve_tab(doc, tab_id=args.tab_id, title=args.title)
        end_index = get_tab_end_index(tab["raw"])
        insert_index = max(1, end_index)
        requests = [
            {
                "insertInlineImage": {
                    "location": {
                        "tabId": tab["tabId"],
                        "index": insert_index,
                    },
                    "uri": args.image_uri,
                    "objectSize": {
                        "width": {"magnitude": args.width_pt, "unit": "PT"},
                        "height": {"magnitude": args.height_pt, "unit": "PT"},
                    },
                }
            }
        ]
        service.documents().batchUpdate(
            documentId=args.document_id, body={"requests": requests}
        ).execute()
        _print({"ok": True, "tabId": tab["tabId"], "imageUri": args.image_uri})
    except Exception as e:
        _print({"ok": False, "error": str(e)})
        sys.exit(1)


def cmd_replace_patent_tabs(args):
    try:
        service = get_docs_service(
            auth_mode=args.auth_mode, account_key=getattr(args, "account_key", None)
        )
        doc = fetch_document(service, args.document_id)
        files = resolve_patent_files(args.patent_dir)
        title_map = {
            "claims": args.claims_title or "Schutzansprüche",
            "description": args.description_title or "Techn. Beschreibung",
            "summary": args.summary_title or "Zusammenfassung",
            "drawings": args.drawings_title or "Zeichnungen",
        }
        result = {}
        for key in ["claims", "description", "summary"]:
            tab = resolve_tab(doc, title=title_map[key])
            text = files[key].read_text(encoding="utf-8") if files[key].exists() else ""
            result[key] = replace_tab_content(service, args.document_id, tab, text)
        drawings_tab = resolve_tab(doc, title=title_map["drawings"])
        drawings_text = (
            files["drawings"].read_text(encoding="utf-8")
            if files["drawings"].exists()
            else ""
        )
        result["drawings"] = replace_tab_content(
            service, args.document_id, drawings_tab, drawings_text
        )
        _print({"ok": True, "documentId": args.document_id, "result": result})
    except Exception as e:
        _print({"ok": False, "error": str(e)})
        sys.exit(1)


def cmd_replace_patent_tabs_live(args):
    import subprocess

    patent_files = resolve_patent_files(args.patent_dir)
    title_map = {
        "claims": args.claims_title or "Schutzansprüche",
        "description": args.description_title or "Techn. Beschreibung",
        "summary": args.summary_title or "Zusammenfassung",
        "drawings": args.drawings_title or "Zeichnungen",
    }
    account_key = args.account_key or DEFAULT_ACCOUNT_KEY
    service = get_docs_service(auth_mode="user_oauth", account_key=account_key)
    doc = fetch_document(service, args.document_id)
    title_to_id = {
        tab["title"]: tab["tabId"]
        for tab in iter_tabs(doc.get("tabs", []))
        if tab.get("title") and tab.get("tabId")
    }
    result = {}
    for key, file_key in [
        ("claims", "claims"),
        ("description", "description"),
        ("summary", "summary"),
        ("drawings", "drawings"),
    ]:
        title = title_map[key]
        tab_id = title_to_id.get(title)
        if not tab_id:
            raise KeyError(f"missing_live_tab:{title}")
        text = (
            patent_files[file_key].read_text(encoding="utf-8")
            if patent_files[file_key].exists()
            else ""
        )
        payload = {
            "action": "google.docs.replace_tab_text",
            "documentId": args.document_id,
            "tabId": tab_id,
            "authMode": "user_oauth",
            "accountKey": account_key,
            "text": text,
            "emergencyPlaintext": True,
            "emergencyReason": "Populate existing user-owned patent tabs via proven OAuth user path.",
            "confirm": True,
        }
        cmd = [
            "node",
            "/Users/jeremy/dev/SIN-Solver/a2a/team-infratructur/A2A-SIN-Google-Apps/dist/src/cli.js",
            "run-action",
            json.dumps(payload, ensure_ascii=False),
        ]
        res = subprocess.run(cmd, capture_output=True, text=True, check=True)
        result[key] = json.loads(res.stdout)
    _print(
        {
            "ok": True,
            "documentId": args.document_id,
            "accountKey": account_key,
            "result": result,
        }
    )


def build_parser():
    parser = argparse.ArgumentParser(prog="sin-google-docs")
    sub = parser.add_subparsers(required=True)

    p = sub.add_parser("tabs")
    p.add_argument("document_id")
    p.add_argument(
        "--auth-mode",
        choices=["service_account", "user_oauth"],
        default="service_account",
    )
    p.add_argument("--account-key")
    p.set_defaults(func=cmd_tabs)

    p = sub.add_parser("read")
    p.add_argument("document_id")
    p.add_argument("--tab-id")
    p.add_argument("--title")
    p.add_argument(
        "--auth-mode",
        choices=["service_account", "user_oauth"],
        default="service_account",
    )
    p.add_argument("--account-key")
    p.set_defaults(func=cmd_read)

    p = sub.add_parser("clear")
    p.add_argument("document_id")
    p.add_argument("--tab-id")
    p.add_argument("--title")
    p.add_argument(
        "--auth-mode",
        choices=["service_account", "user_oauth"],
        default="service_account",
    )
    p.add_argument("--account-key")
    p.set_defaults(func=cmd_clear)

    p = sub.add_parser("replace")
    p.add_argument("document_id")
    p.add_argument("--tab-id")
    p.add_argument("--title")
    p.add_argument("--text")
    p.add_argument("--text-file")
    p.add_argument(
        "--auth-mode",
        choices=["service_account", "user_oauth"],
        default="service_account",
    )
    p.add_argument("--account-key")
    p.set_defaults(func=cmd_replace)

    p = sub.add_parser("append")
    p.add_argument("document_id")
    p.add_argument("--tab-id")
    p.add_argument("--title")
    p.add_argument("--text")
    p.add_argument("--text-file")
    p.add_argument(
        "--auth-mode",
        choices=["service_account", "user_oauth"],
        default="service_account",
    )
    p.add_argument("--account-key")
    p.set_defaults(func=cmd_append)

    p = sub.add_parser("ensure-access")
    p.add_argument("file_id")
    p.add_argument("--grantee-email")
    p.add_argument("--role", default="writer")
    p.add_argument("--notify", action="store_true")
    p.add_argument(
        "--auth-mode",
        choices=["service_account", "user_oauth"],
        default="service_account",
    )
    p.add_argument("--account-key")
    p.set_defaults(func=cmd_ensure_access)

    p = sub.add_parser("self-share-browser")
    p.add_argument("document_id")
    p.add_argument("--grantee-email")
    p.add_argument(
        "--profile",
        default="/Users/jeremy/.config/google/sin-google-apps/chrome-profiles/private-main",
    )
    p.add_argument("--port", type=int, default=9445)
    p.set_defaults(func=cmd_self_share_browser)

    p = sub.add_parser("create-child-tab")
    p.add_argument("document_id")
    p.add_argument("--parent-tab-id")
    p.add_argument("--parent-title")
    p.add_argument("--title", required=True)
    p.set_defaults(func=cmd_create_child_tab)

    p = sub.add_parser("ensure-patent-structure")
    p.add_argument("document_id")
    p.add_argument("--claims-title")
    p.add_argument("--description-title")
    p.add_argument("--summary-title")
    p.add_argument("--drawings-title")
    p.add_argument(
        "--auth-mode",
        choices=["service_account", "user_oauth"],
        default="service_account",
    )
    p.add_argument("--account-key")
    p.set_defaults(func=cmd_ensure_patent_structure)

    p = sub.add_parser("insert-image")
    p.add_argument("document_id")
    p.add_argument("--tab-id")
    p.add_argument("--title")
    p.add_argument("--image-uri", required=True)
    p.add_argument("--width-pt", type=int, default=360)
    p.add_argument("--height-pt", type=int, default=240)
    p.add_argument(
        "--auth-mode",
        choices=["service_account", "user_oauth"],
        default="service_account",
    )
    p.add_argument("--account-key")
    p.set_defaults(func=cmd_insert_image)

    p = sub.add_parser("replace-patent-tabs")
    p.add_argument("document_id")
    p.add_argument("--patent-dir", required=True)
    p.add_argument("--claims-title")
    p.add_argument("--description-title")
    p.add_argument("--summary-title")
    p.add_argument("--drawings-title")
    p.add_argument(
        "--auth-mode",
        choices=["service_account", "user_oauth"],
        default="service_account",
    )
    p.add_argument("--account-key")
    p.set_defaults(func=cmd_replace_patent_tabs)

    p = sub.add_parser("replace-patent-tabs-live")
    p.add_argument("document_id")
    p.add_argument("--patent-dir", required=True)
    p.add_argument("--claims-title")
    p.add_argument("--description-title")
    p.add_argument("--summary-title")
    p.add_argument("--drawings-title")
    p.add_argument("--account-key", default=DEFAULT_ACCOUNT_KEY)
    p.set_defaults(func=cmd_replace_patent_tabs_live)

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
