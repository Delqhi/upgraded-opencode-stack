# ── Commands ──────────────────────────────────────────────────────────────────
def cmd_templates(args, host, key):
    print("Available templates:\n")
    for name, tpl in TEMPLATES.items():
        print(f"  {name}")
        print(f"    {tpl['_description']}")
        vars_needed = tpl.get("_vars", [])
        if vars_needed:
            print(f"    vars: {', '.join(vars_needed)}")
        print()


def cmd_list(args, host, key):
    workflows = get_all_workflows(host, key)
    if args.active_only:
        workflows = [w for w in workflows if w.get("active")]
    if not workflows:
        print("No workflows found.")
        return
    print(f"{'ID':<22} {'ACTIVE':<8} {'NAME'}")
    print("-" * 70)
    for wf in workflows:
        active = "✅" if wf.get("active") else "  "
        print(f"{wf['id']:<22} {active:<8} {wf['name']}")


def cmd_get(args, host, key):
    wf = resolve_workflow(host, key, args.id_or_name)
    print(json.dumps(wf, indent=2))


def cmd_create(args, host, key):
    template_name = args.template
    if template_name not in TEMPLATES:
        print(
            f"Unknown template '{template_name}'. Run `sin-n8n templates` to list available.",
            file=sys.stderr,
        )
        sys.exit(1)

    tpl = copy.deepcopy(TEMPLATES[template_name])
    # Strip meta keys
    workflow = {k: v for k, v in tpl.items() if not k.startswith("_")}

    # Apply --name
    if args.name:
        workflow["name"] = args.name

    # Apply --vars substitutions (replace {{VAR}} in JSON string)
    wf_str = json.dumps(workflow)
    if args.vars:
        for pair in args.vars:
            if "=" not in pair:
                print(
                    f"Bad --vars format: '{pair}' — expected KEY=VALUE", file=sys.stderr
                )
                sys.exit(1)
            k, v = pair.split("=", 1)
            wf_str = wf_str.replace(f"{{{{{k}}}}}", v)
    workflow = json.loads(wf_str)

    # Only send allowed fields
    clean = {k: v for k, v in workflow.items() if k in ALLOWED_CREATE_FIELDS}
    if "settings" not in clean:
        clean["settings"] = {"executionOrder": "v1"}

    result = _req(host, key, "POST", "/workflows", clean)
    print(f"✅ Created workflow '{result['name']}' id={result['id']}")
    print(f"   Activate: sin-n8n activate {result['id']}")
    return result["id"]


def cmd_activate(args, host, key):
    wf = resolve_workflow(host, key, args.id_or_name)
    result = _req(host, key, "POST", f"/workflows/{wf['id']}/activate", {})
    print(
        f"✅ Activated '{result['name']}' (id={result['id']}) active={result.get('active')}"
    )


def cmd_deactivate(args, host, key):
    wf = resolve_workflow(host, key, args.id_or_name)
    result = _req(host, key, "POST", f"/workflows/{wf['id']}/deactivate", {})
    print(
        f"⏸  Deactivated '{result['name']}' (id={result['id']}) active={result.get('active')}"
    )


def cmd_delete(args, host, key):
    wf = resolve_workflow(host, key, args.id_or_name)
    if not args.force:
        confirm = (
            input(f"Delete '{wf['name']}' (id={wf['id']})? [y/N] ").strip().lower()
        )
        if confirm != "y":
            print("Cancelled.")
            return
    _req(host, key, "DELETE", f"/workflows/{wf['id']}")
    print(f"🗑  Deleted '{wf['name']}' (id={wf['id']})")


def cmd_run(args, host, key):
    wf = resolve_workflow(host, key, args.id_or_name)
    payload = {}
    if args.data:
        try:
            payload = json.loads(args.data)
        except json.JSONDecodeError as e:
            print(f"Bad --data JSON: {e}", file=sys.stderr)
            sys.exit(1)
    result = _req(
        host,
        key,
        "POST",
        f"/workflows/{wf['id']}/run",
        {"workflowData": wf, "runData": payload},
    )
    exec_id = result.get("executionId") or result.get("id") or "?"
    print(f"▶  Execution started: id={exec_id}")
    if args.wait:
        import time

        print("   Waiting for completion...", end="", flush=True)
        for _ in range(60):
            time.sleep(2)
            ex = _req(host, key, "GET", f"/executions/{exec_id}")
            status = ex.get("status", "unknown")
            if status in ("success", "error", "crashed", "canceled"):
                print(f" {status}")
                if ex.get("data", {}).get("resultData", {}).get("error"):
                    print("  Error:", ex["data"]["resultData"]["error"].get("message"))
                return
            print(".", end="", flush=True)
        print(" timeout")


def cmd_logs(args, host, key):
    wf = resolve_workflow(host, key, args.id_or_name)
    limit = args.limit or 10
    result = _req(host, key, "GET", f"/executions?workflowId={wf['id']}&limit={limit}")
    executions = result.get("data", [])
    if not executions:
        print(f"No executions found for '{wf['name']}'.")
        return
    print(f"Last {len(executions)} executions for '{wf['name']}' (id={wf['id']}):\n")
    print(f"{'EXEC ID':<28} {'STATUS':<12} {'STARTED':<28} {'DURATION'}")
    print("-" * 90)
    for ex in executions:
        status = ex.get("status", "?")
        started = ex.get("startedAt", "?")
        duration_ms = ex.get("stoppedAt") and ex.get("startedAt") and "?"
        print(
            f"{ex.get('id', '?'):<28} {status:<12} {started:<28} {duration_ms or '?'}"
        )


# ── Main ──────────────────────────────────────────────────────────────────────
def main():
    parser = argparse.ArgumentParser(
        prog="sin-n8n",
        description="A2A CLI for n8n workflow automation on OCI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  sin-n8n templates
  sin-n8n create http-poller --name "HackerOne Poller" --vars POLL_URL=https://api.hackerone.com CRON_EXPR="0 * * * *"
  sin-n8n list --active-only
  sin-n8n activate my-workflow
  sin-n8n run my-workflow --data '{"param":"value"}' --wait
  sin-n8n logs my-workflow --limit 5
  sin-n8n delete my-workflow --force
""",
    )
    parser.add_argument("--host", help="n8n host (overrides N8N_HOST env)")
    parser.add_argument("--key", help="n8n API key (overrides N8N_API_KEY env)")

    subparsers = parser.add_subparsers(dest="command", required=True)

    # templates
    subparsers.add_parser("templates", help="List built-in workflow templates")

    # list
    p_list = subparsers.add_parser("list", help="List workflows")
    p_list.add_argument(
        "--active-only", action="store_true", help="Only show active workflows"
    )

    # get
    p_get = subparsers.add_parser("get", help="Get workflow JSON by id or name")
    p_get.add_argument("id_or_name")

    # create
    p_create = subparsers.add_parser("create", help="Create workflow from a template")
    p_create.add_argument("template", help="Template name (see `sin-n8n templates`)")
    p_create.add_argument("--name", help="Workflow name override")
    p_create.add_argument(
        "--vars", nargs="*", metavar="KEY=VALUE", help="Template variable substitutions"
    )
    p_create.add_argument(
        "--activate", action="store_true", help="Activate immediately after creation"
    )

    # activate
    p_act = subparsers.add_parser("activate", help="Activate a workflow")
    p_act.add_argument("id_or_name")

    # deactivate
    p_deact = subparsers.add_parser("deactivate", help="Deactivate a workflow")
    p_deact.add_argument("id_or_name")

    # delete
    p_del = subparsers.add_parser("delete", help="Delete a workflow")
    p_del.add_argument("id_or_name")
    p_del.add_argument("--force", action="store_true", help="Skip confirmation prompt")

    # run
    p_run = subparsers.add_parser("run", help="Execute a workflow")
    p_run.add_argument("id_or_name")
    p_run.add_argument("--data", help="JSON data to pass as runData")
    p_run.add_argument(
        "--wait", action="store_true", help="Wait for execution to complete"
    )

    # logs
    p_logs = subparsers.add_parser("logs", help="Show recent executions for a workflow")
    p_logs.add_argument("id_or_name")
    p_logs.add_argument(
        "--limit", type=int, default=10, help="Number of executions (default: 10)"
    )

    args = parser.parse_args()

    host, key = get_config()
    if args.host:
        host = args.host.rstrip("/")
    if args.key:
        key = args.key

    dispatch = {
        "templates": cmd_templates,
        "list": cmd_list,
        "get": cmd_get,
        "create": cmd_create,
        "activate": cmd_activate,
        "deactivate": cmd_deactivate,
        "delete": cmd_delete,
        "run": cmd_run,
        "logs": cmd_logs,
    }

    fn = dispatch.get(args.command)
    if fn:
        fn(args, host, key)
        # post-create auto-activate
        if args.command == "create" and getattr(args, "activate", False):
            # Re-run activate with the newly created id
            # (cmd_create printed the id; we need to call activate)
            wfs = get_all_workflows(host, key)
            name = args.name or TEMPLATES[args.template]["name"]
            new_wf = next((w for w in wfs if w["name"] == name), None)
            if new_wf:
                _req(host, key, "POST", f"/workflows/{new_wf['id']}/activate", {})
                print(f"✅ Activated immediately.")
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
