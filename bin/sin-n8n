#!/usr/bin/env python3
"""
sin-n8n — A2A CLI for creating, listing, activating, running and deleting n8n workflows.

A2A agents use this to self-build reusable n8n workflows for any repetitive task
instead of executing the same steps manually every time.

Usage:
  sin-n8n create <template> [--name "My Workflow"] [--vars KEY=VALUE ...]
  sin-n8n list [--active-only]
  sin-n8n activate <id-or-name>
  sin-n8n deactivate <id-or-name>
  sin-n8n run <id-or-name> [--data '{"key":"val"}'] [--wait]
  sin-n8n delete <id-or-name>
  sin-n8n logs <id-or-name> [--limit N]
  sin-n8n templates
  sin-n8n get <id-or-name>

Env:
  N8N_HOST     default: http://92.5.60.87:5678
  N8N_API_KEY  default: from ~/.config/opencode/n8n.env or hardcoded fallback
"""

import argparse
import json
import os
import sys
import urllib.request
import urllib.error
import copy
from typing import Optional

# ── Config ────────────────────────────────────────────────────────────────────
DEFAULT_HOST = "http://92.5.60.87:5678"
DEFAULT_API_KEY = ""  # Must be read from n8n.env
ALLOWED_CREATE_FIELDS = {
    "name",
    "nodes",
    "connections",
    "settings",
    "staticData",
    "pinData",
}


def get_config():
    host = os.environ.get("N8N_HOST", DEFAULT_HOST).rstrip("/")
    key = os.environ.get("N8N_API_KEY", "")
    # Try reading from env file
    env_file = os.path.expanduser("~/.config/opencode/n8n.env")
    if not key and os.path.exists(env_file):
        with open(env_file) as f:
            for line in f:
                line = line.strip()
                if line.startswith("N8N_API_KEY="):
                    key = line.split("=", 1)[1].strip().strip('"')
                elif line.startswith("N8N_HOST="):
                    host = line.split("=", 1)[1].strip().strip('"').rstrip("/")
    if not key:
        key = DEFAULT_API_KEY
    return host, key


# ── HTTP helpers ───────────────────────────────────────────────────────────────
def _req(host, key, method, path, body=None):
    url = f"{host}/api/v1{path}"
    headers = {"X-N8N-API-KEY": key, "Content-Type": "application/json"}
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(url, data=data, headers=headers, method=method)
    try:
        resp = urllib.request.urlopen(req)
        raw = resp.read().decode()
        return json.loads(raw) if raw else {}
    except urllib.error.HTTPError as e:
        body_txt = e.read().decode()
        print(f"ERROR {e.code} {method} {path}: {body_txt[:400]}", file=sys.stderr)
        sys.exit(1)


def get_all_workflows(host, key):
    result = _req(host, key, "GET", "/workflows?limit=250")
    return result.get("data", [])


def resolve_workflow(host, key, id_or_name: str):
    """Return workflow dict by id or name (case-insensitive)."""
    workflows = get_all_workflows(host, key)
    # Exact id match
    for wf in workflows:
        if wf["id"] == id_or_name:
            return wf
    # Name match (case-insensitive)
    needle = id_or_name.lower()
    matches = [wf for wf in workflows if wf["name"].lower() == needle]
    if len(matches) == 1:
        return matches[0]
    if len(matches) > 1:
        print(
            f"Ambiguous name '{id_or_name}' matches {len(matches)} workflows. Use id.",
            file=sys.stderr,
        )
        for m in matches:
            print(f"  id={m['id']} name={m['name']}", file=sys.stderr)
        sys.exit(1)
    # Partial name
    matches = [wf for wf in workflows if needle in wf["name"].lower()]
    if len(matches) == 1:
        return matches[0]
    if len(matches) > 1:
        print(
            f"Ambiguous partial name '{id_or_name}'. Use full name or id.",
            file=sys.stderr,
        )
        for m in matches:
            print(f"  id={m['id']} name={m['name']}", file=sys.stderr)
        sys.exit(1)
    print(f"Workflow not found: {id_or_name}", file=sys.stderr)
    sys.exit(1)


