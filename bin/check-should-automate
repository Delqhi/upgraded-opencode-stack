            "like last time",
            "same workflow",
            "i already did this",
            "we already did this",
        ],
        "description": "Repeated manual action detected",
        "template": "http-poller",
        "example_vars": "",
        "reason": "You are about to repeat something you already did manually. This should be a workflow.",
    },
]


def score_text(text: str, keywords: list) -> int:
    text_lower = text.lower()
    return sum(1 for kw in keywords if kw in text_lower)


def detect(task_description: str) -> list:
    results = []
    for pattern in PATTERNS:
        score = score_text(task_description, pattern["keywords"])
        if score > 0:
            results.append({**pattern, "score": score})
    results.sort(key=lambda x: x["score"], reverse=True)
    return results


def fmt_warning(match: dict) -> str:
    lines = [
        f"\n⚠️  AUTOMATE THIS — A2A INEFFICIENCY DETECTED",
        f"   Pattern : {match['description']}",
        f"   Reason  : {match['reason']}",
        f'   Template: sin-n8n create {match["template"]} --name "My Workflow"',
    ]
    if match["example_vars"]:
        lines.append(f"   Vars    : --vars {match['example_vars']}")
    lines += [
        f"",
        f"   ➜ Run: sin-n8n create {match['template']} --activate",
        f"   ➜ Then: sin-n8n list --active-only",
        f"",
        f"   If you MUST run this manually, proceed — but create the workflow afterwards.",
    ]
    return "\n".join(lines)


def main():
    parser = argparse.ArgumentParser(
        prog="check-should-automate",
        description="A2A Inefficiency Detector — warns when a task should be a reusable n8n workflow.",
    )
    parser.add_argument("task", nargs="+", help="Task description (natural language)")
    parser.add_argument(
        "--json",
        dest="as_json",
        action="store_true",
        help="Output machine-readable JSON",
    )
    parser.add_argument(
        "--strict",
        action="store_true",
        help="Exit code 1 when automation is recommended",
    )
    args = parser.parse_args()

    task_description = " ".join(args.task)
    matches = detect(task_description)

    if args.as_json:
        print(
            json.dumps(
                {
                    "task": task_description,
                    "should_automate": len(matches) > 0,
                    "top_match": matches[0] if matches else None,
                    "all_matches": matches,
                },
                indent=2,
            )
        )
        sys.exit(2 if matches and args.strict else 0)

    if not matches:
        print("✅ No automation pattern detected. Proceed manually.")
        sys.exit(0)

    top = matches[0]
    print(fmt_warning(top))

    if len(matches) > 1:
        print(f"   Also matched: {', '.join(m['description'] for m in matches[1:3])}")

    sys.exit(2 if args.strict else 0)


if __name__ == "__main__":
    main()
