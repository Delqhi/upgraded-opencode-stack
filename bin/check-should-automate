        ],
        "description": "Full survey money-earning flow: search → fill → log → notify",
        "template": "full-survey-flow",
        "example_vars": "SEARCH_URL=https://api.prolific.com/api/v1/studies SHEET_ID=1abc... TELEGRAM_CHAT_ID=123",
        "reason": "This is the complete money-earning survey pipeline. Build it once in n8n.",
    },
    {
        "id": "repeated-action",
        "keywords": [
            "again",
