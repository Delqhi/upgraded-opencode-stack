#!/usr/bin/env python3
"""
check-should-automate — A2A Inefficiency Detector

A2A agents call this before executing repetitive tasks.
If the pattern matches known automatable flows, it prints a warning
and suggests the appropriate `sin-n8n create <template>` command.

Usage:
  check-should-automate <task_description>
  check-should-automate --json <task_description>     # machine-readable output
  check-should-automate --strict <task_description>   # exit 1 when should automate

Exit codes:
  0 = no automation recommended (proceed manually)
  2 = automation strongly recommended (--strict causes exit 1)
"""

import sys
import json
import re
import argparse

PATTERNS = [
    {
        "id": "http-poll",
        "keywords": [
            "poll",
            "fetch",
            "check url",
            "scrape url",
            "call api",
            "http get",
            "http request",
            "every hour",
            "every day",
            "every minute",
            "schedule",
            "cron",
            "periodic",
            "repeated fetch",
        ],
        "description": "Periodic HTTP polling / scheduled API call",
        "template": "http-poller",
        "example_vars": "POLL_URL=https://api.example.com CRON_EXPR='0 * * * *'",
        "reason": "Polling a URL repeatedly is a classic n8n schedule+http-request pattern.",
    },
    {
        "id": "google-sheets",
        "keywords": [
            "google sheet",
            "spreadsheet",
            "read sheet",
