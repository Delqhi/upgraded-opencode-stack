// ╔══════════════════════════════════════════════════════════════════╗
// ║  MY-SIN-TEAM-INFRASTRUCTURE.json — TEAM INFRA AGENTEN+MODELLE   ║
// ╠══════════════════════════════════════════════════════════════════╣
// ║  TEAM: Team Infrastructure                                       ║
// ║  MANAGER: A2A-SIN-Team-Infrastructure                            ║
// ║  ZWECK: Deployment, CI/CD, Monitoring, Infrastructure, Security  ║
// ╚══════════════════════════════════════════════════════════════════╝
{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // Team-Info
  "team": {
    "name": "Team Infrastructure",
    "manager": "A2A-SIN-Team-Infrastructure",
    "description": "DevOps-Flotte fuer Deployment, CI/CD, Monitoring, Infrastructure"
  },

  // ═══════════════════════════════════════════════════════════
  // TEAM AGENTEN — Spezifische Modelle pro Team-Mitglied
  // ═══════════════════════════════════════════════════════════
  "agents": {

    // DEPLOY AGENT — Deployment Automation
    // Vercel, Cloudflare, HF Spaces, OCI VM
    "deploy": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ],
      "role": "deployment-specialist",
      "description": "Deployment Automation — Vercel, Cloudflare, HF Spaces, OCI"
    },

    // MONITORING AGENT — System Monitoring
    // Health Checks, Alerts, Performance
    "monitoring": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ],
      "role": "monitoring-specialist",
      "description": "Health Checks, Alerts, Performance-Monitoring"
    },

    // SECURITY AGENT — Security Audits
    // Vulnerability Scanning, Secret Detection
    "security": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ],
      "role": "security-specialist",
      "description": "Vulnerability Scanning, Secret Detection, Security Audits",
      "reasoningEffort": "xhigh"
    }
  },

  // ═══════════════════════════════════════════════════════════
  // TEAM KATEGORIEN — Modell-Auswahl nach Task-Typ
  // ═══════════════════════════════════════════════════════════
  "categories": {

    // Infrastructure Setup — Server, Services einrichten
    "setup": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // Deployment — Code deployen
    "deployment": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // Monitoring — System ueberwachen
    "monitoring": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    },

    // Security — Security Audits
    "security": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "nvidia-nim/z-ai/glm5.1",
        "nvidia-nim/nvidia/nemotron-3-super-120b-a12b",
        "nvidia-nim/stepfun-ai/step-3.5-flash"
      ]
    }
  }
}
