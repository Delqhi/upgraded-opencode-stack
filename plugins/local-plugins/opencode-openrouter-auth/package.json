{
  "name": "opencode-openrouter-auth",
  "version": "1.0.0",
  "description": "OpenRouter OAuth authentication plugin for OpenCode - Access OpenRouter models with your openrouter.ai account via PKCE OAuth",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm",
    "dev": "bun run --watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "openrouter",
    "oauth",
    "pkce",
    "authentication",
    "ai",
    "llm",
    "opencode-plugins"
  ],
  "author": "OpenSIN-AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenSIN-AI/opencode-openrouter-auth.git"
  },
  "homepage": "https://github.com/OpenSIN-AI/opencode-openrouter-auth#readme",
  "devDependencies": {
    "@opencode-ai/plugin": "^1.1.48",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "files": [
    "index.ts",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}